# Runtime Shell Configuration

PORT=3100
AUTH_TOKEN=                    # Bearer token for webhook auth (leave empty to disable)
DB_PATH=./agent.db             # SQLite database path

# Agent Identity
AGENT_NAME=Agent
AGENT_ROLE=worker

# Behaviour
CONFIDENCE_THRESHOLD=0.4       # Below this → escalate
MAX_CYCLES=20                  # Safety limit per activation

# Team Communication
OUTBOUND_WEBHOOK_URL=          # URL to POST escalation/comms messages (e.g. Slack incoming webhook)

# LLM Provider (used by your reason() implementation)
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=
